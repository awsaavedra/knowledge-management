# .envrc — direnv hook for auto-activating the KM project environment.
#
# Setup (one-time per machine):
#   1. Install direnv: https://direnv.net/docs/installation.html
#   2. Hook your shell:  eval "$(direnv hook bash)"  (or zsh/fish)
#   3. From this directory:  direnv allow .
#
# After that, cd-ing into this project auto-sources env.sh — NVIM_APPNAME,
# VIMINIT, LG_CONFIG_FILE, MPV_HOME, PATH, and venv activation all kick in
# automatically. Leaving the directory unsets them.

source_env env.sh
