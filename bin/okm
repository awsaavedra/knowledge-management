        ;;
    esac
    echo "Created: $file"
  else
    echo "Exists: $file"
  fi
  exec "$EDITOR_CMD" "$file"
}

open_obsidian() {
  flatpak run md.obsidian.Obsidian >/dev/null 2>&1 &
}

# === okm audit ===
# Pre-share gate: scan tracked content for PARA notes, secret patterns, and
# sensitive filenames. Tracked files only — `git ls-files` plus staged
# additions. Untracked files are out of scope (they can't be pushed).
audit_usage() {
  cat <<'EOF'
Usage: okm audit [--code-only|--vault-only] [--paths PATH...] [--quiet]

Scan tracked content (vault by default) for:
  - PARA content under daily/, inbox/, archive/, attachments/, private-*/
    (skipping inbox/templates/ and demo-* files)
  - Secret patterns: AWS keys, GitHub tokens, BEGIN ... PRIVATE KEY blocks
  - Sensitive filenames: .env*, *.pem, *.key, *.crt, *credentials*, id_rsa*

Flags:
  --code-only    Scan the project repo (where bin/okm lives) and skip the
                 PARA-content check. Useful before contributing harnesses
                 upstream. Combine with --paths to narrow further.
  --vault-only   Scan only the vault. Same as the default; listed for
                 explicit semantics.
  --paths P...   Restrict findings to files at or under the listed paths
                 (relative to the scan root).
  --quiet        Suppress per-finding output; just set the exit code.

Exit codes:  0 clean  ·  1 findings  ·  2 usage error
EOF
}

audit_run() {
  local code_only=false vault_only=false quiet=false
  local restrict_paths=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --code-only)  code_only=true;  shift ;;
      --vault-only) vault_only=true; shift ;;
      --quiet)      quiet=true;      shift ;;
      --paths)
        shift
        while [ $# -gt 0 ] && [[ "$1" != --* ]]; do
          restrict_paths+=("$1"); shift
        done ;;
      -h|--help) audit_usage; return 0 ;;
      *) echo "okm audit: unknown flag '$1' (try --help)" >&2; exit 2 ;;
    esac
  done

  if $code_only && $vault_only; then
    echo "okm audit: --code-only and --vault-only are mutually exclusive" >&2
    exit 2
  fi

  local root
  if $code_only; then
    root="$OKM_SCRIPT_DIR"
  else
    root="$VAULT"
  fi

  if [ ! -d "${root}/.git" ]; then
    echo "okm audit: ${root} is not a git repository — nothing to scan" >&2
    exit 2
  fi

  local files
  files="$(
    {
      git -C "$root" ls-files 2>/dev/null
      git -C "$root" diff --cached --name-only --diff-filter=A 2>/dev/null
    } | sort -u
  )"

  if [ ${#restrict_paths[@]} -gt 0 ] && [ -n "$files" ]; then
    local filtered=""
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      for p in "${restrict_paths[@]}"; do
        case "$f" in
          "$p"|"$p"/*) filtered+="${f}"$'\n'; break ;;
        esac
      done
    done <<< "$files"
    files="$filtered"
  fi

  local findings=0 out=""
  if [ -n "$files" ]; then
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      local full="$root/$f" base
      base="$(basename "$f")"
      [ -e "$full" ] || continue

      # 1. PARA content (skipped under --code-only).
      if ! $code_only; then
        local skip=false
        case "$f" in inbox/templates/*) skip=true ;; esac
        case "$base" in demo-*) skip=true ;; esac
        if ! $skip; then
          case "$f" in
            daily/*.md|inbox/*.md|archive/*.md)
              out+="${f}:1: para-content user note in public PARA folder"$'\n'
              findings=$((findings+1)) ;;
            attachments/*)
              out+="${f}:1: para-content attachment"$'\n'
              findings=$((findings+1)) ;;
            private-*/*)
              out+="${f}:1: para-content file in private-*/"$'\n'
              findings=$((findings+1)) ;;
          esac
        fi
      fi

      # 2. Sensitive filenames.
      case "$base" in
        .env|.env.*|*.pem|*.key|*.crt|*credentials*|id_rsa|id_rsa.*|id_ed25519|id_ed25519.*)
          out+="${f}:1: sensitive-filename matches forbidden pattern"$'\n'
          findings=$((findings+1)) ;;
      esac

      # 3. Secret patterns (text-file content scan; -I skips binary).
      if [ -f "$full" ]; then
        local matches
        matches="$(grep -InE \
          '(AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{40,}|-----BEGIN [A-Z ]*PRIVATE KEY-----)' \
          "$full" 2>/dev/null || true)"
        if [ -n "$matches" ]; then
          while IFS= read -r m; do
            [ -n "$m" ] || continue
            out+="${f}:${m%%:*}: secret-pattern match"$'\n'
            findings=$((findings+1))
          done <<< "$matches"
        fi
      fi
    done <<< "$files"
  fi

  if [ "$findings" -eq 0 ]; then
    if ! $quiet; then
      local count
      count="$(printf '%s' "$files" | grep -c . || true)"
      echo "okm audit: clean (${root}, ${count} tracked files scanned)"
    fi
    return 0
  fi

  if ! $quiet; then
    echo "okm audit: ${findings} finding(s) in ${root}:" >&2
    printf '%s' "$out" | sort -u
  fi
  return 1
}

case "${1:-help}" in
  open) shift; open_note "${1:-}" ;;
  new) shift; new_note "$@" ;;
  capture) shift; capture_note "$@" ;;
  today) shift; today_note ;;
  spot) shift; spot_note "$@" ;;
  grep) shift; grep_vault "${1:-}" ;;
  files) shift; files_vault "${1:-}" ;;
  recent) shift; recent_notes ;;
  sync) shift; sync_git "$*" ;;
  tags) shift; list_tags "${1:-}" ;;
  tag) shift; add_tags "$@" ;;
  untag) shift; remove_tags "$@" ;;
  tagged) shift; list_tagged "${1:-}" ;;
  audit) shift; audit_run "$@" ;;
  obs) shift; open_obsidian ;;
  path) printf '%s\n' "$VAULT" ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
