#!/usr/bin/env bash
set -euo pipefail

OKM_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [ -z "${OBSIDIAN_VAULT:-}" ]; then
  _parent="$(cd "${OKM_SCRIPT_DIR}/.." && pwd)"
  _sibling="${_parent}/knowledge-management"
  if [ "${_sibling}" = "${OKM_SCRIPT_DIR}" ]; then
    VAULT="${OKM_SCRIPT_DIR}"
  else
    VAULT="${_sibling}"
  fi
  unset _parent _sibling
else
  VAULT="${OBSIDIAN_VAULT}"
fi
EDITOR_CMD="${EDITOR:-vim}"
DAILY_DIR="${OBSIDIAN_DAILY_DIR:-daily}"
NOTES_DIR="${OBSIDIAN_NOTES_DIR:-inbox}"

# Privacy: by default, read-side commands (grep, tags, files, tagged, recent)
# skip private-*/ folders so screen-shared `okm grep` can't surface private
# notes. Set KM_INCLUDE_PRIVATE=1 to opt in to scanning private folders.
# Explicit `okm tags <private-path>` and `okm open <private-path>` still work
# — this only affects vault-walking commands.
PRIVATE_RG_GLOBS=()
PRIVATE_FIND_PRUNE=()
if [ "${KM_INCLUDE_PRIVATE:-0}" != "1" ]; then
  PRIVATE_RG_GLOBS=(--glob '!private-*/')
  PRIVATE_FIND_PRUNE=(-not -path "$VAULT/private-*/*")
fi

usage() {
  cat <<'EOF'
okm - simple terminal knowledge manager

Usage:
  okm open [path]
  okm new <title> [-t tag1,tag2]
  okm capture [text] [-t tag1,tag2]
  okm today
  okm spot <spotify-url> [-t tag1,tag2]
  okm grep <pattern>
  okm files [pattern]
  okm recent
  okm sync [message]
  okm tags [note]
  okm tag <note> <tag> [...]
  okm untag <note> <tag> [...]
  okm tagged <tag>
  okm obs
  okm path
EOF
}

need_cmd() { command -v "$1" >/dev/null 2>&1 || { echo "Missing: $1" >&2; exit 1; }; }
slugify() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'; }
iso_now() { date -Iseconds; }
timestamp() { date +"%Y%m%d-%H%M%S"; }

ensure_dirs() {
  mkdir -p "$VAULT/$DAILY_DIR" "$VAULT/$NOTES_DIR"
}

# Extract the tags: line from a note's YAML frontmatter
get_tags_line() {
  local file="$1"
  sed -n '/^---$/,/^---$/{/^tags:/p;}' "$file"
}

# Parse a YAML tags line into a newline-separated list of tag names
parse_tags() {
  local line="$1"
  echo "$line" | sed 's/^tags:[[:space:]]*//; s/^\[//; s/\]$//; s/,/ /g' \
    | tr ' ' '\n' | sed '/^$/d'
}

# Build a YAML tags array string from newline-separated tag list
build_tags_yaml() {
  local tag_list="$1"
  if [ -z "$tag_list" ]; then
    echo "tags: []"
    return
  fi
  local csv
  csv="$(echo "$tag_list" | paste -sd, - | sed 's/,/, /g')"
  echo "tags: [${csv}]"
}

# Resolve a note argument to an absolute file path inside the vault.
resolve_note() {
  local arg="$1"
  if [ -f "$arg" ]; then
    echo "$arg"
  elif [ -f "$VAULT/$arg" ]; then
    echo "$VAULT/$arg"
  else
    echo "Note not found: $arg" >&2
    return 1
  fi
}

# List all tags across the vault with counts, or show tags for a specific note
list_tags() {
  local note="${1:-}"
  if [ -n "$note" ]; then
    local file
    file="$(resolve_note "$note")"
    local line
    line="$(get_tags_line "$file")"
    if [ -z "$line" ]; then
      echo "(no tags)"
      return
    fi
    parse_tags "$line"
    return
  fi
  need_cmd rg
  rg -n --no-heading --glob '*.md' --glob '!.git/' "${PRIVATE_RG_GLOBS[@]}" '^tags:' "$VAULT" 2>/dev/null \
    | sed 's/^.*tags:[[:space:]]*//; s/^\[//; s/\]$//; s/,/ /g' \
    | tr ' ' '\n' \
    | sed '/^$/d' \
    | sort | uniq -c | sort -rn \
    | awk '{printf "%-4d %s\n", $1, $2}'
}

# Add tags to a note
add_tags() {
  local note="${1:-}"
  [ -n "$note" ] || { echo "Note required" >&2; exit 1; }
  shift
  [ $# -gt 0 ] || { echo "At least one tag required" >&2; exit 1; }

  local file
  file="$(resolve_note "$note")"

  local line
  line="$(get_tags_line "$file")"
  local existing=""
  if [ -n "$line" ]; then
    existing="$(parse_tags "$line")"
  fi

  local merged="$existing"
  for t in "$@"; do
    if ! echo "$merged" | grep -qxF "$t"; then
      merged="${merged:+${merged}
}${t}"
    fi
  done

  local new_yaml
  new_yaml="$(build_tags_yaml "$merged")"

  if [ -n "$line" ]; then
    sed -i "/^---$/,/^---$/{s/^tags:.*$/${new_yaml}/;}" "$file"
  else
    sed -i "0,/^---$/!{0,/^---$/s/^---$/${new_yaml}\n---/}" "$file"
  fi
  echo "Tagged: $(basename "$file") -> ${new_yaml}"
}

# Remove tags from a note
remove_tags() {
  local note="${1:-}"
  [ -n "$note" ] || { echo "Note required" >&2; exit 1; }
  shift
  [ $# -gt 0 ] || { echo "At least one tag required" >&2; exit 1; }

  local file
  file="$(resolve_note "$note")"

  local line
  line="$(get_tags_line "$file")"
  if [ -z "$line" ]; then
    echo "No tags to remove"
    return
  fi

  local existing
  existing="$(parse_tags "$line")"

  local remaining=""
  while IFS= read -r tag; do
    local keep=true
    for t in "$@"; do
      if [ "$tag" = "$t" ]; then
        keep=false
        break
      fi
    done
    if $keep; then
      remaining="${remaining:+${remaining}
}${tag}"
    fi
  done <<< "$existing"

  local new_yaml
  new_yaml="$(build_tags_yaml "$remaining")"
  sed -i "/^---$/,/^---$/{s/^tags:.*$/${new_yaml}/;}" "$file"
  echo "Updated: $(basename "$file") -> ${new_yaml}"
}

# List notes with a specific tag
list_tagged() {
  local tag="${1:-}"
  [ -n "$tag" ] || { echo "Tag required" >&2; exit 1; }
  need_cmd rg
  # rg exits 1 when no matches; treat as graceful empty result (not an error)
  local matches
  matches="$(rg -l --glob '*.md' --glob '!.git/' "${PRIVATE_RG_GLOBS[@]}" "^tags:.*\\b${tag}\\b" "$VAULT" 2>/dev/null || true)"
  [ -z "$matches" ] && return 0
  printf '%s\n' "$matches" | sed "s#^$VAULT/##" | sort
}

# Parse -t flag from arguments.
# Sets _REMAINING_ARGS array and TAG_FLAG_VALUES string.
TAG_FLAG_VALUES=""
_REMAINING_ARGS=()
parse_tag_flag() {
  TAG_FLAG_VALUES=""
  _REMAINING_ARGS=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -t)
        shift
        [ $# -gt 0 ] || { echo "-t requires comma-separated tags" >&2; exit 1; }
        TAG_FLAG_VALUES="$1"
        shift
        ;;
      *)
        _REMAINING_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

list_notes() {
  find "$VAULT" -type f -name '*.md' "${PRIVATE_FIND_PRUNE[@]}" | sed "s#^$VAULT/##"
}

pick_file() {
  need_cmd fzf
  list_notes | sort | fzf --height=40% --reverse --border --prompt="notes> "
}

open_note() {
  ensure_dirs
  local target="${1:-}"
  if [ -z "$target" ]; then
    local picked
    picked="$(pick_file || true)"
    [ -n "${picked:-}" ] || exit 0
    exec "$EDITOR_CMD" "$VAULT/$picked"
  fi
  if [ -e "$target" ]; then
    exec "$EDITOR_CMD" "$target"
  else
    exec "$EDITOR_CMD" "$VAULT/$target"
  fi
}

new_note() {
  ensure_dirs
  parse_tag_flag "$@"
  local title="${_REMAINING_ARGS[*]:-}"
  [ -n "$title" ] || { echo "Title required" >&2; exit 1; }

  local tags_yaml="[]"
  if [ -n "$TAG_FLAG_VALUES" ]; then
    tags_yaml="[$(echo "$TAG_FLAG_VALUES" | sed 's/,/, /g')]"
  fi

  local slug file
  slug="$(slugify "$title")"
  file="$VAULT/$NOTES_DIR/$slug.md"
  [ -f "$file" ] || cat > "$file" <<EOF
---
title: "${title}"
created: $(iso_now)
tags: ${tags_yaml}
---

# ${title}

EOF
  exec "$EDITOR_CMD" "$file"
}

capture_note() {
  ensure_dirs
  parse_tag_flag "$@"
  local body="${_REMAINING_ARGS[*]:-}"

  local tags_yaml="[capture, inbox]"
  if [ -n "$TAG_FLAG_VALUES" ]; then
    tags_yaml="[capture, inbox, $(echo "$TAG_FLAG_VALUES" | sed 's/,/, /g')]"
  fi

  local file ts
  ts="$(timestamp)"
  file="$VAULT/$NOTES_DIR/$ts.md"
  cat > "$file" <<EOF
---
title: "Quick Capture ${ts}"
created: $(iso_now)
tags: ${tags_yaml}
---

# Quick Capture ${ts}

${body:-}
EOF
  exec "$EDITOR_CMD" "$file"
}

today_note() {
  ensure_dirs
  local d file
  d="$(date +%F)"
  file="$VAULT/$DAILY_DIR/$d.md"
  [ -f "$file" ] || cat > "$file" <<EOF
---
date: $d
created: $(iso_now)
tags: [daily]
---

# $d

## Tasks

- [ ]

## Notes

EOF
  exec "$EDITOR_CMD" "$file"
}

grep_vault() {
  need_cmd rg
  local pattern="${1:-}"
  [ -n "$pattern" ] || { echo "Pattern required" >&2; exit 1; }
  rg -n --hidden --glob '*.md' --glob '!.git/' "${PRIVATE_RG_GLOBS[@]}" "$pattern" "$VAULT"
}

files_vault() {
  local pattern="${1:-}"
  if [ -z "$pattern" ]; then
    list_notes | sort
  else
    list_notes | grep -i -- "$pattern" | sort || true
  fi
}

recent_notes() {
  need_cmd fzf
  local picked
  picked="$(
    find "$VAULT" -type f -name '*.md' "${PRIVATE_FIND_PRUNE[@]}" -exec stat --format='%Y %n' {} + 2>/dev/null \
      || find "$VAULT" -type f -name '*.md' "${PRIVATE_FIND_PRUNE[@]}" -print0 | xargs -0 stat -f '%m %N' 2>/dev/null \
      | sort -nr \
      | head -200 \
      | cut -d' ' -f2- \
      | sed "s#^$VAULT/##" \
      | fzf --height=40% --reverse --border --prompt="recent> "
  )"
  [ -n "${picked:-}" ] || exit 0
  exec "$EDITOR_CMD" "$VAULT/$picked"
}

sync_git() {
  git -C "$VAULT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    echo "Vault is not a git repo" >&2
    exit 1
  }
  local msg="${*:-vault sync $(date '+%F %T')}"
  git -C "$VAULT" add -A
  if git -C "$VAULT" diff --cached --quiet; then
    echo "No changes to commit"
  else
    git -C "$VAULT" commit -m "$msg"
  fi
  local upstream
  upstream="$(git -C "$VAULT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  if [ -n "$upstream" ]; then
    git -C "$VAULT" pull --rebase --autostash
    git -C "$VAULT" push
  else
    echo "No upstream configured; skipped pull/push"
  fi
}

spot_note() {
  ensure_dirs
  parse_tag_flag "$@"
  local url="${_REMAINING_ARGS[0]:-}"
  [ -n "$url" ] || { echo "Spotify URL required" >&2; exit 1; }

  # Validate it's a Spotify URL
  case "$url" in
    *open.spotify.com/*|*spotify:*) ;;
    *) echo "Not a Spotify URL: $url" >&2; exit 1 ;;
  esac

  # Determine content type from URL
  local spot_type="track"
  case "$url" in
    *episode*) spot_type="episode" ;;
    *show*)    spot_type="show" ;;
    *album*)   spot_type="album" ;;
    *playlist*) spot_type="playlist" ;;
    *track*)   spot_type="track" ;;
  esac

  # Extract Spotify ID for embed URL
  local spot_id embed_url
  spot_id="$(echo "$url" | sed -E 's#.*/[a-z]+/([a-zA-Z0-9]+)(\?.*)?$#\1#')"
  embed_url="https://open.spotify.com/embed/${spot_type}/${spot_id}"

  # Try spotdl for metadata (tracks/albums/playlists)
  local title="" artist=""
  if command -v spotdl >/dev/null 2>&1 && [ "$spot_type" != "episode" ] && [ "$spot_type" != "show" ]; then
    local meta
    meta="$(spotdl save "$url" --output "{artist} - {title}" 2>/dev/null | head -1 || true)"
    if [ -n "$meta" ]; then
      artist="$(echo "$meta" | sed 's/ - .*//')"
      title="$(echo "$meta" | sed 's/^[^-]*- //')"
    fi
  fi

  # Fallback title from URL slug
  if [ -z "$title" ]; then
    title="$(echo "$url" | sed -E 's|.*/[a-zA-Z]+/[a-zA-Z0-9]+[?/]?||; s/[?#].*//' | tr '-' ' ')"
    [ -n "$title" ] || title="Spotify ${spot_type} ${spot_id}"
  fi

  local slug file
  slug="$(slugify "$title")"
  file="$VAULT/$NOTES_DIR/$slug.md"

  local source_tag="source/spotify"
  case "$spot_type" in
    episode|show) source_tag="source/podcast" ;;
    track|album)  source_tag="source/music" ;;
    playlist)     source_tag="source/playlist" ;;
  esac

  local tags_csv="${source_tag}"
  if [ -n "$TAG_FLAG_VALUES" ]; then
    tags_csv="${source_tag}, $(echo "$TAG_FLAG_VALUES" | sed 's/,/, /g')"
  fi

  if [ ! -f "$file" ]; then
    case "$spot_type" in
      episode|show)
        cat > "$file" <<EOF
---
title: "${title}"
source_type: spotify-${spot_type}
source_url: "${url}"
author: "${artist}"
created: $(iso_now)
tags: [${tags_csv}]
---

# ${title}

## Player

[Listen on Spotify](${url})

<iframe src="${embed_url}" width="100%" height="352" frameBorder="0" allowfullscreen allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>

## Summary

<!-- caveman speech: short sentences, no filler, bullets over paragraphs -->

-

## Key Quotes

> [MM:SS] "..."

## Transcript

<!-- okm distill or whisperX after downloading audio -->

EOF
        ;;
      *)
        cat > "$file" <<EOF
---
title: "${title}"
source_type: spotify-${spot_type}
source_url: "${url}"
author: "${artist}"
created: $(iso_now)
tags: [${tags_csv}]
---

# ${title}

## Player

[Listen on Spotify](${url})

<iframe src="${embed_url}" width="100%" height="352" frameBorder="0" allowfullscreen allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>

## Notes

-

EOF
        ;;
    esac
    echo "Created: $file"
  else
    echo "Exists: $file"
  fi
  exec "$EDITOR_CMD" "$file"
}

open_obsidian() {
  flatpak run md.obsidian.Obsidian >/dev/null 2>&1 &
}

case "${1:-help}" in
  open) shift; open_note "${1:-}" ;;
  new) shift; new_note "$@" ;;
  capture) shift; capture_note "$@" ;;
  today) shift; today_note ;;
  spot) shift; spot_note "$@" ;;
  grep) shift; grep_vault "${1:-}" ;;
  files) shift; files_vault "${1:-}" ;;
  recent) shift; recent_notes ;;
  sync) shift; sync_git "$*" ;;
  tags) shift; list_tags "${1:-}" ;;
  tag) shift; add_tags "$@" ;;
  untag) shift; remove_tags "$@" ;;
  tagged) shift; list_tagged "${1:-}" ;;
  obs) shift; open_obsidian ;;
  path) printf '%s\n' "$VAULT" ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
