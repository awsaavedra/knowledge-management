#!/usr/bin/env bash
set -euo pipefail

OKM_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [ -z "${OBSIDIAN_VAULT:-}" ]; then
  _parent="$(cd "${OKM_SCRIPT_DIR}/.." && pwd)"
  _sibling="${_parent}/knowledge-management"
  if [ "${_sibling}" = "${OKM_SCRIPT_DIR}" ]; then
    VAULT="${OKM_SCRIPT_DIR}"
  else
    VAULT="${_sibling}"
  fi
  unset _parent _sibling
else
  VAULT="${OBSIDIAN_VAULT}"
fi
EDITOR_CMD="${EDITOR:-vim}"
DAILY_DIR="${OBSIDIAN_DAILY_DIR:-public/daily}"
NOTES_DIR="${OBSIDIAN_NOTES_DIR:-public/inbox}"

OKM_VERSION="1.0.0"
KM_TRACK_NOTES="${KM_TRACK_NOTES:-true}"

# Privacy: by default, read-side commands (grep, tags, files, tagged, recent)
# skip private/ folder so screen-shared `okm grep` can't surface private
# notes. Set KM_INCLUDE_PRIVATE=1 to opt in to scanning private folders.
# Explicit `okm tags <private-path>` and `okm open <private-path>` still work
# — this only affects vault-walking commands.
PRIVATE_RG_GLOBS=()
PRIVATE_FIND_PRUNE=()
if [ "${KM_INCLUDE_PRIVATE:-0}" != "1" ]; then
  PRIVATE_RG_GLOBS=(--glob '!private/')
  PRIVATE_FIND_PRUNE=(-not -path "$VAULT/private/*")
fi
FIND_GIT_PRUNE=(-not -path '*/.git/*')

usage() {
  cat <<'EOF'
okm - simple terminal knowledge manager

Usage:
  okm open [path]
  okm new <title> [-t tag1,tag2]
  okm capture [text] [-t tag1,tag2]
  okm today [-t tag1,tag2]              # opens this week's note (YYYY-MM-DD-weekly.md, Mon–Sun)
  okm spot <spotify-url> [-t tag1,tag2]
  okm yt <youtube-url> [-t tag1,tag2]
  okm pod <audio-file> [title] [-t tag1,tag2]
  okm distill <note> [--model claude|ollama]
  okm grep <pattern>
  okm files [substring]
  okm recent
  okm sync [-m message]
  okm tags [note] [--json]
  okm tag <note> <tag> [...]
  okm untag <note> <tag> [...]
  okm tagged <tag>
  okm rename-tag <old> <new>
  okm audit [--code-only|--vault-only] [--paths PATH...] [--quiet] [--json]
  okm private <new|today|capture|yt|spot|pod> [args...]
  okm crypt init
  okm port <github-handle> [--no-push]
  okm obs
  okm path
  okm version
EOF
}

need_cmd() { command -v "$1" >/dev/null 2>&1 || { echo "Missing: $1" >&2; exit 1; }; }

# shellcheck source=scripts/lib/privacy.sh
source "${OKM_SCRIPT_DIR}/scripts/lib/privacy.sh"
# shellcheck source=scripts/lib/media.sh
source "${OKM_SCRIPT_DIR}/scripts/lib/media.sh"   # spot, yt, pod, distill
# shellcheck source=scripts/lib/platform.sh
source "${OKM_SCRIPT_DIR}/scripts/lib/platform.sh"   # _date_add (portable week math)

# N20: collapse vertical whitespace before slugifying.
# N14: fail-closed on empty/short slugs. N18: cap at 200 chars.
slugify() {
  local raw
  raw="$(printf '%s' "$1" | tr '\n\r\t' '   ')"
  local slug
  slug="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
  if [ "${#slug}" -lt 2 ]; then
    echo "Title produces empty or too-short slug — use ASCII letters/digits in the title" >&2
    return 1
  fi
  if [ "${#slug}" -gt 200 ]; then
    slug="${slug:0:200}"
    slug="${slug%-}"
  fi
  printf '%s' "$slug"
}

# N13+N26: escape backslashes then double-quotes in YAML double-quoted scalars.
# Backslash must be escaped first so we don't double-escape the quote escapes.
# Newlines/CRs/tabs are stripped to prevent YAML frontmatter injection.
yaml_escape_dq() {
  local s="${1//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/ }"
  s="${s//$'\r'/}"
  s="${s//$'\t'/ }"
  printf '%s' "$s"
}

iso_now() { date -Iseconds; }
timestamp() { date +"%Y%m%d-%H%M%S"; }

ensure_dirs() {
  mkdir -p "$VAULT/$DAILY_DIR" "$VAULT/$NOTES_DIR"
}

# Tag character whitelist: ASCII letters, digits, and `_./+-`. Rejects
# whitespace, brackets, colons, quotes, commas, pipes (sed delimiter), and
# anything else that would break YAML or shell-flag parsing.
# Closes B4 + N23 (invalid-char rejection) and removes the `-leading` flag
# vector for `grep` in N22 (we still pass `--` defensively below).
validate_tag() {
  local tag="$1"
  if [ -z "$tag" ]; then
    echo "Invalid tag: empty" >&2
    return 1
  fi
  if [[ ! "$tag" =~ ^[A-Za-z0-9_./+-]+$ ]]; then
    echo "Invalid tag '$tag': only [A-Za-z0-9_./+-] allowed (no spaces, brackets, colons, quotes, commas, pipes)" >&2
    return 1
  fi
}

# True if file starts with a valid YAML frontmatter block (opening AND closing ---).
# N30: a lone leading --- (horizontal rule) is not frontmatter.
has_frontmatter() {
  local file="$1"
  [ -s "$file" ] || return 1
  [ "$(head -n1 "$file")" = "---" ] || return 1
  awk 'NR > 1 && /^---$/ { found = 1; exit } END { exit !found }' "$file"
}

# Print the body of the first YAML frontmatter block (between the first two
# `---` lines). Closes N21: body `---...---` blocks are no longer scanned.
first_frontmatter() {
  awk '
    /^---$/ {
      c++
      if (c == 1) next
      if (c == 2) exit
    }
    c == 1 { print }
  ' "$1"
}

# True if first frontmatter uses block-style YAML for tags
# (`tags:` followed by indented `- foo` lines). Closes B3 detection.
has_block_style_tags() {
  first_frontmatter "$1" | awk '
    /^tags:[[:space:]]*$/ { in_tags = 1; next }
    in_tags && /^[[:space:]]+-[[:space:]]/ { found = 1; exit }
    in_tags && /^[^[:space:]]/ { in_tags = 0 }
    END { exit !found }
  '
}

# Extract the tags: line from the first frontmatter only (N21).
get_tags_line() {
  first_frontmatter "$1" | sed -n '/^tags:/p' | head -n1
}

# Read tags from a file as a newline-separated list. Handles both inline
# (tags: [a, b]) and block-style (tags:\n  - a) YAML. Returns empty if none.
# Always exits 0 so callers don't trip set -e on files with no tags key.
read_file_tags() {
  local file="$1"
  if has_block_style_tags "$file"; then
    first_frontmatter "$file" | awk '
      /^tags:[[:space:]]*$/ { in_tags = 1; next }
      in_tags && /^[[:space:]]+-[[:space:]]+/ { tag = $0; sub(/^[[:space:]]+-[[:space:]]+/, "", tag); print tag; next }
      in_tags && /^[^[:space:]]/ { exit }
    '
  else
    local line
    line="$(get_tags_line "$file")"
    if [ -n "$line" ]; then
      parse_tags "$line"
    fi
  fi
}

# Parse a YAML inline-array tags line into a newline-separated list.
parse_tags() {
  local line="$1"
  echo "$line" | sed 's/^tags:[[:space:]]*//; s/^\[//; s/\]$//; s/,/ /g' \
    | tr ' ' '\n' | sed '/^$/d'
}

# Build a YAML tags array string from a newline-separated tag list.
build_tags_yaml() {
  local tag_list="$1"
  if [ -z "$tag_list" ]; then
    echo "tags: []"
    return
  fi
  local csv
  csv="$(echo "$tag_list" | paste -sd, - | sed 's/,/, /g')"
  echo "tags: [${csv}]"
}

# Build a tags YAML value from optional default tags and the -t flag output.
# Reads TAG_FLAG_VALUES (set by parse_tag_flag). Returns [defaults, extra] or [].
_tags_yaml() {
  local defaults="${1:-}"
  local extra
  extra="$(printf '%s' "${TAG_FLAG_VALUES:-}" | sed 's/,/, /g')"
  if [ -n "$defaults" ] && [ -n "$extra" ]; then
    printf '[%s, %s]' "$defaults" "$extra"
  elif [ -n "$extra" ]; then
    printf '[%s]' "$extra"
  elif [ -n "$defaults" ]; then
    printf '[%s]' "$defaults"
  else
    printf '[]'
  fi
}

# Shared fzf picker: height/border/prompt are uniform across all note pickers.
_fzf_pick() { fzf --height=40% --reverse --border --prompt="${1:-notes}> "; }

# N30: lone --- (horizontal rule) is not frontmatter — hard-fail before tagging.
_hr_frontmatter_guard() {
  local file="$1" verb="${2:-tag}"
  if [ "$(head -n1 "$file")" = "---" ] && ! has_frontmatter "$file"; then
    echo "Cannot ${verb}: '$(basename "$file")' starts with '---' but has no valid frontmatter" >&2
    exit 1
  fi
}

# Assert a resolved path is inside the vault; prints message and returns 1 if not.
_assert_in_vault() {
  local resolved="$1" vault_real="$2" ctx="${3:-path}"
  case "$resolved" in
    "$vault_real"|"$vault_real"/*) return 0 ;;
    *) echo "${ctx}: path resolves outside the vault" >&2; return 1 ;;
  esac
}

# Rewrite the tags line inside the first frontmatter block. If no tags line
# exists in the first frontmatter, insert one immediately before the closing
# `---`. Body content (including any later `---...---` blocks) is preserved
# verbatim. Handles both inline and block-style (B3); preserves file permissions (N31).
write_tags_line() {
  local file="$1"
  local new_line="$2"
  local tmp orig_perms
  tmp="$(mktemp -- "${file}.XXXXXX")"
  orig_perms="$(stat -c '%a' "$file" 2>/dev/null)" || orig_perms=""
  awk -v new_line="$new_line" '
    BEGIN { c = 0; replaced = 0; in_after = 0; skip_block = 0 }
    {
      if ($0 == "---") {
        c++
        if (c == 2 && !replaced) { print new_line; replaced = 1 }
        skip_block = 0
        print
        if (c >= 2) in_after = 1
        next
      }
      if (in_after) { print; next }
      if (skip_block) {
        if (/^[[:space:]]+-[[:space:]]/) { next }
        skip_block = 0
      }
      if (c == 1 && /^tags:/ && !replaced) {
        if (/^tags:[[:space:]]*$/) { skip_block = 1 }
        print new_line
        replaced = 1
        next
      }
      print
    }
  ' "$file" > "$tmp" && mv "$tmp" "$file"
  [ -n "$orig_perms" ] && chmod "$orig_perms" "$file" 2>/dev/null || true
}

# Refuse if the file uses block-style YAML tags. Hard-fail per B3 in v0;
# read-side block-style support is a v1 item.
require_inline_tags() {
  local file="$1"
  if has_block_style_tags "$file"; then
    {
      echo "Refusing: $file uses block-style YAML tags (multi-line list)."
      echo "Convert to inline form before using okm tag/untag, e.g.:"
      echo "  tags: [foo, bar]"
    } >&2
    exit 1
  fi
}

# Resolve a note argument to an absolute file path inside the vault.
# N28: refuses paths that resolve outside the vault (same guard as N19 for open).
resolve_note() {
  local arg="$1"
  local resolved=""
  if [ -f "$arg" ]; then
    resolved="$(realpath -- "$arg" 2>/dev/null || true)"
  elif [ -f "$VAULT/$arg" ]; then
    resolved="$(realpath -- "$VAULT/$arg" 2>/dev/null || true)"
  else
    echo "Note not found: $arg" >&2
    return 1
  fi
  local vault_real
  vault_real="$(realpath -- "$VAULT" 2>/dev/null || true)"
  _assert_in_vault "$resolved" "$vault_real" "okm" || return 1
  echo "$resolved"
}

# Walk vault .md files honouring the private-folder default.
list_vault_md_files() {
  find "$VAULT" -type f -name '*.md' \
    "${FIND_GIT_PRUNE[@]}" "${PRIVATE_FIND_PRUNE[@]}" -print 2>/dev/null
}

# List all tags across the vault with counts, or show tags for a specific note.
list_tags() {
  local json=false note=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) json=true; shift ;;
      *) note="$1"; shift ;;
    esac
  done

  if [ -n "$note" ]; then
    local file
    file="$(resolve_note "$note")"
    local tags
    tags="$(read_file_tags "$file")"
    if [ -z "$tags" ]; then
      echo "(no tags)"
      return
    fi
    echo "$tags"
    return
  fi
  local files
  files="$(list_vault_md_files)"
  [ -n "$files" ] || return 0
  local counts
  counts="$(
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      read_file_tags "$f"
    done <<< "$files" \
      | sed '/^$/d' \
      | sort | uniq -c | sort -rn
  )"
  if $json; then
    printf '[\n'
    local first=true
    while IFS= read -r line; do
      [ -n "$line" ] || continue
      local count tag
      count="$(printf '%s' "$line" | awk '{print $1}')"
      tag="$(printf '%s' "$line" | awk '{$1=""; sub(/^ /,"",$0); print}')"
      $first || printf ',\n'
      printf '  {"tag":"%s","count":%s}' "$tag" "$count"
      first=false
    done <<< "$counts"
    printf '\n]\n'
  else
    printf '%s\n' "$counts" | awk '{printf "%-4d %s\n", $1, $2}'
  fi
}

# Add tags to a note. Validates each tag, refuses block-style files, and
# prepends a frontmatter block if the file doesn't have one (N11).
add_tags() {
  local note="${1:-}"
  [ -n "$note" ] || { echo "Note required" >&2; exit 1; }
  shift
  [ $# -gt 0 ] || { echo "At least one tag required" >&2; exit 1; }

  for t in "$@"; do
    validate_tag "$t" || exit 1
  done

  local file
  file="$(resolve_note "$note")"

  _hr_frontmatter_guard "$file" "tag"

  if ! has_frontmatter "$file"; then
    local tmp orig_perms
    tmp="$(mktemp -- "${file}.XXXXXX")"
    orig_perms="$(stat -c '%a' "$file" 2>/dev/null)" || orig_perms=""
    {
      printf -- '---\ntags: []\n---\n'
      cat "$file"
    } > "$tmp" && mv "$tmp" "$file"
    [ -n "$orig_perms" ] && chmod "$orig_perms" "$file" 2>/dev/null || true
  fi

  local existing
  existing="$(read_file_tags "$file")"

  local merged="$existing"
  for t in "$@"; do
    # `--` defends against tag values that start with `-` reaching grep as a flag (N22).
    if ! printf '%s\n' "$merged" | grep -qxF -- "$t"; then
      merged="${merged:+${merged}
}${t}"
    fi
  done

  local new_yaml
  new_yaml="$(build_tags_yaml "$merged")"
  write_tags_line "$file" "$new_yaml"
  echo "Tagged: $(basename "$file") -> ${new_yaml}"
}

# Remove tags from a note.
remove_tags() {
  local note="${1:-}"
  [ -n "$note" ] || { echo "Note required" >&2; exit 1; }
  shift
  [ $# -gt 0 ] || { echo "At least one tag required" >&2; exit 1; }

  for t in "$@"; do
    validate_tag "$t" || exit 1
  done

  local file
  file="$(resolve_note "$note")"

  _hr_frontmatter_guard "$file" "untag"

  if ! has_frontmatter "$file"; then
    echo "No tags to remove (no frontmatter)"
    return
  fi

  local existing
  existing="$(read_file_tags "$file")"
  if [ -z "$existing" ]; then
    echo "No tags to remove"
    return
  fi

  local remaining=""
  while IFS= read -r tag; do
    [ -n "$tag" ] || continue
    local keep=true
    for t in "$@"; do
      if [ "$tag" = "$t" ]; then
        keep=false
        break
      fi
    done
    if $keep; then
      remaining="${remaining:+${remaining}
}${tag}"
    fi
  done <<< "$existing"

  local new_yaml
  new_yaml="$(build_tags_yaml "$remaining")"
  write_tags_line "$file" "$new_yaml"
  echo "Updated: $(basename "$file") -> ${new_yaml}"
}

# List notes with a specific tag. Uses parsed-tag equality, not regex match,
# so `okm tagged source` does NOT also match `source/spotify` (B2), and
# `okm tagged '.*'` is just an invalid tag, not a regex (N17).
# B3: block-style YAML files are included via read_file_tags but we warn if any exist.
list_tagged() {
  local tag="${1:-}"
  [ -n "$tag" ] || { echo "Tag required" >&2; exit 1; }
  validate_tag "$tag" || exit 1

  local files
  files="$(list_vault_md_files)"
  [ -n "$files" ] || return 0

  local out="" block_skipped=0
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    if has_block_style_tags "$f"; then
      block_skipped=$((block_skipped + 1))
    fi
    local tags
    tags="$(read_file_tags "$f")"
    [ -n "$tags" ] || continue
    if printf '%s\n' "$tags" | grep -qxF -- "$tag"; then
      out="${out:+${out}
}${f#$VAULT/}"
    fi
  done <<< "$files"
  if [ -n "$out" ]; then
    printf '%s\n' "$out" | sort
  fi
  if [ "$block_skipped" -gt 0 ]; then
    echo "${block_skipped} note(s) with block-style tags skipped (v1)" >&2
  fi
}

# Parse -t flag from arguments.
# Sets _REMAINING_ARGS array and TAG_FLAG_VALUES string.
TAG_FLAG_VALUES=""
_REMAINING_ARGS=()
parse_tag_flag() {
  TAG_FLAG_VALUES=""
  _REMAINING_ARGS=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -t)
        shift
        [ $# -gt 0 ] || { echo "-t requires comma-separated tags" >&2; exit 1; }
        # N27: validate every tag in the comma-separated list before accepting.
        local IFS=','
        for _tag in $1; do
          _tag="$(printf '%s' "$_tag" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
          [ -n "$_tag" ] || continue
          validate_tag "$_tag" || exit 1
        done
        unset IFS
        TAG_FLAG_VALUES="$1"
        shift
        ;;
      *)
        _REMAINING_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

list_notes() {
  find "$VAULT" -type f -name '*.md' \
    "${FIND_GIT_PRUNE[@]}" "${PRIVATE_FIND_PRUNE[@]}" | sed "s#^$VAULT/##"
}

pick_file() {
  need_cmd fzf
  list_notes | sort | _fzf_pick "notes"
}

open_note() {
  ensure_dirs
  local target="${1:-}"
  if [ -z "$target" ]; then
    local picked
    picked="$(pick_file || true)"
    [ -n "${picked:-}" ] || exit 0
    exec "$EDITOR_CMD" "$VAULT/$picked"
  fi

  local final
  if [ -e "$target" ]; then
    final="$target"
  else
    final="$VAULT/$target"
  fi

  # N19: refuse paths that resolve outside the vault. realpath -m resolves
  # even non-existent paths so `okm open new-note.md` still works.
  local resolved vault_real
  resolved="$(realpath -m -- "$final" 2>/dev/null || true)"
  vault_real="$(realpath -- "$VAULT" 2>/dev/null || true)"
  if [ -z "$resolved" ] || [ -z "$vault_real" ]; then
    echo "okm open: cannot resolve target or vault path" >&2
    exit 1
  fi
  case "$resolved" in
    "$vault_real"|"$vault_real"/*) ;;
    *)
      echo "okm open: refusing path that resolves outside the vault." >&2
      echo "  vault:    $vault_real" >&2
      echo "  resolved: $resolved" >&2
      exit 1 ;;
  esac

  exec "$EDITOR_CMD" "$final"
}

new_note() {
  ensure_dirs
  parse_tag_flag "$@"
  local title="${_REMAINING_ARGS[*]:-}"
  [ -n "$title" ] || { echo "Title required" >&2; exit 1; }

  local tags_yaml; tags_yaml="$(_tags_yaml)"

  local slug file
  slug="$(slugify "$title")" || exit 1
  file="$VAULT/$NOTES_DIR/$slug.md"
  local safe_title
  safe_title="$(yaml_escape_dq "$title")"
  [ -f "$file" ] || cat > "$file" <<EOF
---
title: "${safe_title}"
created: $(iso_now)
tags: ${tags_yaml}
---

# ${title}

## Context

## Notes

## Links

EOF
  exec "$EDITOR_CMD" "$file"
}

capture_note() {
  ensure_dirs
  parse_tag_flag "$@"
  local body="${_REMAINING_ARGS[*]:-}"

  local tags_yaml; tags_yaml="$(_tags_yaml "capture, inbox")"

  local file ts
  ts="$(timestamp)"
  file="$VAULT/$NOTES_DIR/$ts.md"
  cat > "$file" <<EOF
---
title: "Quick Capture ${ts}"
created: $(iso_now)
tags: ${tags_yaml}
---

# Quick Capture ${ts}

${body:-}
EOF
  exec "$EDITOR_CMD" "$file"
}

# Pull unfinished tasks from the most recent prior weekly note so they roll
# into the new week — same idea as the weekly-tasks.sh cron carry-forward, but
# for the simple "## Tasks" list in okm today's weekly note. Emits one
# "- [ ] item" line per unchecked, non-empty task; checked items (- [x]) and the
# empty "- [ ]" placeholder are left behind. Searches within $DAILY_DIR, so the
# public and private sides each carry forward independently.
_carry_forward_tasks() {
  local cur_week_start="$1" dir="$VAULT/$DAILY_DIR" prev
  # Newest weekly note strictly before this week (ISO date prefix sorts chronologically).
  prev="$(
    find "$dir" -maxdepth 1 -name '*-weekly.md' 2>/dev/null \
      | sed 's#.*/##' \
      | sort \
      | awk -v cur="${cur_week_start}-weekly.md" '$0 < cur' \
      | tail -1
  )"
  [ -n "$prev" ] || return 0
  awk '
    /^## Tasks[[:space:]]*$/ { intasks=1; next }
    /^## /                   { intasks=0 }
    intasks && /^- \[ \]/ {
      rest = $0
      sub(/^- \[ \][[:space:]]*/, "", rest)
      if (rest != "") print "- [ ] " rest
    }
  ' "$dir/$prev"
}

# Opens the current week's note (Mon–Sun), named <week-start>-weekly.md.
# "today" is kept as the command name; it resolves to the week containing today.
today_note() {
  ensure_dirs
  parse_tag_flag "$@"
  local today dow week_start week_end file
  today="$(date +%F)"
  dow="$(date +%u)"                               # 1=Mon … 7=Sun
  week_start="$(_date_add "$today" "-$((dow - 1))")"
  week_end="$(_date_add "$today" "+$((7 - dow))")"
  file="$VAULT/$DAILY_DIR/${week_start}-weekly.md"
  local tags_yaml; tags_yaml="$(_tags_yaml "weekly")"
  if [ ! -f "$file" ]; then
    # Roll unfinished tasks from the previous week's note into this one.
    local carried; carried="$(_carry_forward_tasks "$week_start")"
    [ -n "$carried" ] && carried="${carried}"$'\n'
    cat > "$file" <<EOF
---
week_start: $week_start
week_end: $week_end
created: $(iso_now)
tags: ${tags_yaml}
---

# Week of $week_start – $week_end

## Captures

## Notes

## Tasks

${carried}- [ ]

## Reflection

EOF
  fi
  exec "$EDITOR_CMD" "$file"
}

grep_vault() {
  need_cmd rg
  local pattern="${1:-}"
  [ -n "$pattern" ] || { echo "Pattern required" >&2; exit 1; }
  rg -n --hidden --glob '*.md' --glob '!.git/' "${PRIVATE_RG_GLOBS[@]}" "$pattern" "$VAULT"
}

files_vault() {
  local pattern="${1:-}"
  if [ -z "$pattern" ]; then
    list_notes | sort
  else
    # A search that matches nothing has succeeded with no results, not failed;
    # swallow grep's exit-1 so the command stays a clean exit 0.
    list_notes | { grep -i -- "$pattern" || true; } | sort
  fi
}

recent_notes() {
  need_cmd fzf
  local picked file_list find_errs
  find_errs="$(mktemp 2>/dev/null || echo "/tmp/okm-recent-errs-$$")"
  file_list="$(
    { find "$VAULT" -type f -name '*.md' "${PRIVATE_FIND_PRUNE[@]}" \
          -exec stat --format='%Y %n' {} + 2>"$find_errs" \
      || find "$VAULT" -type f -name '*.md' "${PRIVATE_FIND_PRUNE[@]}" \
          -print0 2>>"$find_errs" | xargs -0 stat -f '%m %N' 2>/dev/null
    }
  )" || true
  if [ -s "$find_errs" ]; then
    echo "okm recent: warn — some vault directories may be unreadable: $VAULT" >&2
  fi
  rm -f "$find_errs" 2>/dev/null || true
  picked="$(
    printf '%s\n' "$file_list" \
      | sort -nr \
      | head -200 \
      | cut -d' ' -f2- \
      | sed "s#^$(printf '%s' "$VAULT" | sed 's/[#&\\/]/\\&/g')/##" \
      | _fzf_pick "recent"
  )" || true  # fzf exits 130 on Escape/Ctrl-C; treat as empty selection
  [ -n "${picked:-}" ] || exit 0
  local resolved vault_real
  resolved="$(realpath -m -- "$VAULT/$picked" 2>/dev/null || true)"
  vault_real="$(realpath -- "$VAULT" 2>/dev/null || true)"
  _assert_in_vault "$resolved" "$vault_real" "okm recent" || exit 1
  exec "$EDITOR_CMD" "$VAULT/$picked"
}

sync_git() {
  # Parse -m flag for custom commit message.
  local msg="" args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -m) shift; msg="${1:-}"; shift ;;
      *)  args+=("$1"); shift ;;
    esac
  done
  # Remaining positional args treated as legacy bare message (okm sync "my msg").
  if [ -z "$msg" ] && [ ${#args[@]} -gt 0 ]; then
    msg="${args[*]}"
  fi
  msg="${msg:-vault sync $(date '+%F %T')}"

  git -C "$VAULT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    echo "Vault is not a git repo" >&2
    exit 1
  }

  # Upstream guard: refuse to push if origin still points at the public OSS repo.
  local origin_url
  origin_url="$(git -C "$VAULT" remote get-url origin 2>/dev/null || true)"
  if [ -n "$origin_url" ]; then
    local blocklist="${KM_UPSTREAM_PATTERN:-knowledge-management}"
    if [[ "$origin_url" =~ $blocklist ]] && [[ "${KM_ALLOW_UPSTREAM_PUSH:-0}" != "1" ]]; then
      echo "okm sync: refusing — origin looks like the public upstream repo." >&2
      echo "  origin: $origin_url" >&2
      echo "  Run 'okm port <handle>' to set up your private fork, or set KM_ALLOW_UPSTREAM_PUSH=1 to override." >&2
      exit 1
    fi
  fi

  # N15: refuse to sync if any symlink in the vault points outside the vault.
  local vault_real bad_links=""
  vault_real="$(realpath -- "$VAULT" 2>/dev/null || true)"
  if [ -n "$vault_real" ]; then
    while IFS= read -r link; do
      [ -n "$link" ] || continue
      local tgt
      tgt="$(realpath -m -- "$link" 2>/dev/null || true)"
      [ -n "$tgt" ] || continue
      case "$tgt" in
        "$vault_real"|"$vault_real"/*) ;;
        *) bad_links+="  ${link} -> ${tgt}"$'\n' ;;
      esac
    done < <(find "$VAULT" -type l "${FIND_GIT_PRUNE[@]}" 2>/dev/null)
  fi
  if [ -n "$bad_links" ]; then
    echo "okm sync: refusing — vault contains symlinks pointing outside the vault:" >&2
    printf '%s' "$bad_links" >&2
    echo "Remove or relocate these before syncing." >&2
    exit 1
  fi

  # Extension guard: warn and abort on suspicious file types before staging.
  if [ "${KM_FORCE_SYNC:-0}" != "1" ]; then
    local suspicious
    suspicious="$(git -C "$VAULT" diff --name-only HEAD -- \
      '*.env' '*.pem' '*.key' '*.crt' '*.db' '*.sqlite' '*.exe' '*.dll' '*.so' '*.dylib' \
      '.env' 2>/dev/null || true)"
    # Also check untracked suspicious files
    local untracked_susp
    untracked_susp="$(git -C "$VAULT" ls-files --others --exclude-standard 2>/dev/null \
      | grep -E '\.(env|pem|key|crt|db|sqlite|exe|dll|so|dylib)$|^\.env$' || true)"
    local all_susp="${suspicious}${untracked_susp}"
    if [ -n "$all_susp" ]; then
      echo "okm sync: suspicious files detected — refusing to stage:" >&2
      printf '%s\n' "$all_susp" | sed 's/^/  /' >&2
      echo "Set KM_FORCE_SYNC=1 to override." >&2
      exit 1
    fi
  fi

  git -C "$VAULT" add -A
  if git -C "$VAULT" diff --cached --quiet; then
    echo "No changes to commit"
  else
    git -C "$VAULT" commit -m "$msg"
  fi
  local upstream
  upstream="$(git -C "$VAULT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  if [ -n "$upstream" ]; then
    # Privacy gate: refuse to push if the remote is a public GitHub repo.
    if ! km_check_remote_is_private "$VAULT"; then
      echo "okm sync: push aborted — see PRIVACY messages above." >&2
      exit 1
    fi
    git -C "$VAULT" pull --rebase --autostash
    git -C "$VAULT" push
  else
    echo "No upstream configured; skipped pull/push"
  fi
}

open_obsidian() {
  flatpak run md.obsidian.Obsidian >/dev/null 2>&1 &
}

# === okm audit ===
# Pre-share gate: scan tracked content for PARA notes, secret patterns, and
# sensitive filenames. Tracked files only — `git ls-files` plus staged
# additions. Untracked files are out of scope (they can't be pushed).
audit_usage() {
  cat <<'EOF'
Usage: okm audit [--code-only|--vault-only] [--paths PATH...] [--quiet]

Scan tracked content (vault by default) for:
  - PARA content under public/{daily,inbox,archive,attachments}/, private/
    (skipping public/inbox/templates/ and demo-* files)
  - Secret patterns: AWS keys, GitHub tokens, BEGIN ... PRIVATE KEY blocks
  - Sensitive filenames: .env*, *.pem, *.key, *.crt, *credentials*, id_rsa*

Flags:
  --code-only    Scan the project repo (where bin/okm lives) and skip the
                 PARA-content check. Useful before contributing harnesses
                 upstream. Combine with --paths to narrow further.
  --vault-only   Scan only the vault. Same as the default; listed for
                 explicit semantics.
  --paths P...   Restrict findings to files at or under the listed paths
                 (relative to the scan root).
  --quiet        Suppress per-finding output; just set the exit code.

Exit codes:  0 clean  ·  1 findings  ·  2 usage error
EOF
}

_audit_collect_files() {
  local root="$1"
  {
    git -C "$root" ls-files 2>/dev/null
    git -C "$root" diff --cached --name-only --diff-filter=A 2>/dev/null
  } | sort -u
}

# stdin: file list (one per line). $@: allowed path prefixes (pass-through if none).
_audit_filter_paths() {
  [ $# -eq 0 ] && { cat; return; }
  local restrict_paths=("$@")
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    for p in "${restrict_paths[@]}"; do
      case "$f" in "$p"|"$p"/*) echo "$f"; break ;; esac
    done
  done
}

# Emit one finding-line per issue in a single tracked file. stdout only.
_audit_check_file() {
  local root="$1" f="$2" code_only="$3"
  local full="$root/$f" base
  base="$(basename "$f")"
  [ -e "$full" ] || return 0

  # 1a. Personal content report — default (vault) scan only.
  if ! $code_only; then
    local skip=false
    case "$f" in public/inbox/templates/*) skip=true ;; esac
    case "$base" in demo-*) skip=true ;; esac
    if ! $skip; then
      case "$f" in
        public/daily/*.md|public/inbox/*.md|public/archive/*.md)
          echo "${f}:1: para-content user note in public PARA folder" ;;
        public/attachments/*)
          echo "${f}:1: para-content attachment" ;;
        private/*/*)
          echo "${f}:1: para-content file in private/" ;;
      esac
    fi
  fi

  # 1b. Contribution guard — under --code-only the tool repo must hold no vault
  #     content (the same invariant the pre-push hook enforces). Demo fixtures
  #     are shareable and exempt.
  if $code_only && km_path_is_vault_content "$f"; then
    case "$base" in
      demo-*) ;;
      *) echo "${f}:1: vault-content must not be committed to the tool repo" ;;
    esac
  fi

  # 2. Sensitive filenames.
  case "$base" in
    .env|.env.*|*.pem|*.key|*.crt|*credentials*|id_rsa|id_rsa.*|id_ed25519|id_ed25519.*)
      echo "${f}:1: sensitive-filename matches forbidden pattern" ;;
  esac

  # 3. Secret patterns (text-file content scan; -I skips binary).
  [ -f "$full" ] || return 0
  local matches
  matches="$(grep -InE \
    '(AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{40,}|-----BEGIN [A-Z ]*PRIVATE KEY-----)' \
    "$full" 2>/dev/null || true)"
  [ -n "$matches" ] || return 0
  while IFS= read -r m; do
    [ -n "$m" ] || continue
    echo "${f}:${m%%:*}: secret-pattern match"
  done <<< "$matches"
}

audit_run() {
  local code_only=false vault_only=false quiet=false json=false
  local restrict_paths=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --code-only)  code_only=true;  shift ;;
      --vault-only) vault_only=true; shift ;;
      --quiet)      quiet=true;      shift ;;
      --json)       json=true;       shift ;;
      --paths)
        shift
        while [ $# -gt 0 ] && [[ "$1" != --* ]]; do
          restrict_paths+=("$1"); shift
        done ;;
      -h|--help) audit_usage; return 0 ;;
      *) echo "okm audit: unknown flag '$1' (try --help)" >&2; exit 2 ;;
    esac
  done

  if $code_only && $vault_only; then
    echo "okm audit: --code-only and --vault-only are mutually exclusive" >&2
    exit 2
  fi

  local root
  if $code_only; then root="$OKM_SCRIPT_DIR"; else root="$VAULT"; fi

  if [ ! -d "${root}/.git" ]; then
    echo "okm audit: ${root} is not a git repository — nothing to scan" >&2
    exit 2
  fi

  local files
  files="$(_audit_collect_files "$root" \
    | _audit_filter_paths "${restrict_paths[@]+"${restrict_paths[@]}"}")"

  local out=""
  if [ -n "$files" ]; then
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      local fout
      fout="$(_audit_check_file "$root" "$f" "$code_only")"
      [ -n "$fout" ] && out+="${fout}"$'\n'
    done <<< "$files"
  fi
  out="$(printf '%s' "$out" | sort -u)"

  local findings=0
  [ -n "$out" ] && findings="$(printf '%s\n' "$out" | grep -c .)"

  if $json; then
    local secrets=0 para=0 filenames=0
    local json_findings="["
    local first_finding=true
    if [ -n "$out" ]; then
      while IFS= read -r line; do
        [ -n "$line" ] || continue
        local fpath fline fdesc jtype
        fpath="$(printf '%s' "$line" | cut -d: -f1)"
        fline="$(printf '%s' "$line" | cut -d: -f2)"
        fdesc="$(printf '%s' "$line" | cut -d: -f3- | sed 's/^ //')"
        case "$fdesc" in
          secret-pattern*)     jtype="secret";   secrets=$((secrets+1)) ;;
          para-content*)       jtype="para";     para=$((para+1)) ;;
          vault-content*)      jtype="para";     para=$((para+1)) ;;
          sensitive-filename*) jtype="filename"; filenames=$((filenames+1)) ;;
          *)                   jtype="$(printf '%s' "$fdesc" | awk '{print $1}')" ;;
        esac
        $first_finding || json_findings+=","
        json_findings+="$(printf '\n  {"type": "%s", "file": "%s", "line": %s, "match": "%s"}' \
          "$jtype" "$fpath" "$fline" "$fdesc")"
        first_finding=false
      done <<< "$out"
    fi
    json_findings+=$'\n]'
    printf '{"findings":%s,"summary":{"total":%s,"secrets":%s,"para":%s,"filenames":%s}}\n' \
      "$json_findings" "$findings" "$secrets" "$para" "$filenames"
    [ "$findings" -eq 0 ]
    return $?
  fi

  if [ "$findings" -eq 0 ]; then
    if ! $quiet; then
      local count
      count="$(printf '%s' "$files" | grep -c . || true)"
      echo "okm audit: clean (${root}, ${count} tracked files scanned)"
    fi
    return 0
  fi

  if ! $quiet; then
    echo "okm audit: ${findings} finding(s) in ${root}:" >&2
    printf '%s\n' "$out"
  fi
  return 1
}

rename_tag() {
  local old_tag="${1:-}" new_tag="${2:-}"
  [ -n "$old_tag" ] || { echo "Old tag required" >&2; exit 1; }
  [ -n "$new_tag" ] || { echo "New tag required" >&2; exit 1; }
  validate_tag "$old_tag" || exit 1
  validate_tag "$new_tag" || exit 1

  local files
  files="$(list_vault_md_files)"
  [ -n "$files" ] || return 0

  local updated=0
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    local tags
    tags="$(read_file_tags "$f")"
    [ -n "$tags" ] || continue
    if printf '%s\n' "$tags" | grep -qxF -- "$old_tag"; then
      require_inline_tags "$f" || continue
      local new_tags
      new_tags="$(printf '%s\n' "$tags" | grep -vxF -- "$old_tag" || true)"
      new_tags="${new_tags:+${new_tags}
}${new_tag}"
      local new_yaml
      new_yaml="$(build_tags_yaml "$new_tags")"
      write_tags_line "$f" "$new_yaml"
      updated=$((updated + 1))
    fi
  done <<< "$files"
  echo "Renamed tag '$old_tag' → '$new_tag' in $updated file(s)"
}

private_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    new)
      NOTES_DIR="private/inbox" new_note "$@" ;;
    today)
      DAILY_DIR="private/daily" NOTES_DIR="private/inbox" today_note "$@" ;;
    capture)
      NOTES_DIR="private/inbox" capture_note "$@" ;;
    yt)
      NOTES_DIR="private/inbox" yt_note "$@" ;;
    spot)
      NOTES_DIR="private/inbox" spot_note "$@" ;;
    pod)
      NOTES_DIR="private/inbox" pod_note "$@" ;;
    *)
      echo "okm private: unknown subcommand '$sub'" >&2
      echo "Usage: okm private <new|today|capture|yt|spot|pod> [args...]" >&2
      exit 1 ;;
  esac
}

crypt_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    init)
      command -v git-crypt >/dev/null 2>&1 || {
        echo "git-crypt is not installed. Install it with: $(_pkg_install_hint git-crypt)" >&2
        exit 1
      }
      git -C "$VAULT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
        echo "okm crypt: vault is not a git repo" >&2
        exit 1
      }
      git-crypt -C "$VAULT" init
      local ga="$VAULT/.gitattributes"
      grep -q 'daily/\*.md filter=git-crypt' "$ga" 2>/dev/null || \
        printf 'public/daily/*.md filter=git-crypt diff=git-crypt\n' >> "$ga"
      grep -q 'inbox/\*.md filter=git-crypt' "$ga" 2>/dev/null || \
        printf 'public/inbox/*.md filter=git-crypt diff=git-crypt\n' >> "$ga"
      local key="${HOME}/git-crypt-km.key"
      git-crypt -C "$VAULT" export-key "$key"
      echo "git-crypt initialised. Key exported to: $key"
      echo "WARNING: Back up $key — key loss = permanent data loss." >&2
      echo "Next: git add .gitattributes && git commit -m 'configure git-crypt'"
      ;;
    *)
      echo "okm crypt: unknown subcommand '$sub'" >&2
      echo "Usage: okm crypt init" >&2
      exit 1 ;;
  esac
}

port_cmd() {
  local handle="${1:-}"
  [ -n "$handle" ] || { echo "GitHub handle required" >&2; exit 1; }
  local no_push=false
  for arg in "$@"; do
    [ "$arg" = "--no-push" ] && no_push=true
  done

  git -C "$VAULT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    echo "okm port: vault is not a git repo" >&2
    exit 1
  }

  # Require clean working tree.
  if [ -n "$(git -C "$VAULT" status --porcelain 2>/dev/null)" ]; then
    echo "okm port: working tree is not clean. Commit or stash changes first." >&2
    exit 1
  fi

  local new_repo="${handle}-knowledge-management"

  # Rename origin → upstream and disable upstream push.
  if git -C "$VAULT" remote get-url origin >/dev/null 2>&1; then
    git -C "$VAULT" remote rename origin upstream
    git -C "$VAULT" remote set-url --push upstream DISABLED
  fi

  # Add new private origin.
  local new_url="git@github.com:${handle}/${new_repo}.git"
  git -C "$VAULT" remote add origin "$new_url" 2>/dev/null || \
    git -C "$VAULT" remote set-url origin "$new_url"

  # Activate the tracked pre-push privacy guard. core.hooksPath keeps the one
  # authoritative copy in scripts/hooks/ — same activation as setup-km.sh.
  local guard_status="core.hooksPath=scripts/hooks"
  if [ -f "$VAULT/scripts/hooks/pre-push" ]; then
    chmod +x "$VAULT/scripts/hooks/pre-push" 2>/dev/null || true
    git -C "$VAULT" config core.hooksPath scripts/hooks
  else
    guard_status="NOT ACTIVATED (scripts/hooks/pre-push missing)"
    echo "okm port: WARNING — scripts/hooks/pre-push not found; privacy guard not activated" >&2
  fi

  if ! $no_push; then
    command -v gh >/dev/null 2>&1 && \
      gh repo create "$new_repo" --private --clone=false 2>/dev/null || true
    git -C "$VAULT" push -u origin main
  fi

  echo "okm port: done."
  echo "  origin  → git@github.com:${handle}/${new_repo}.git"
  echo "  upstream push → DISABLED"
  echo "  privacy guard → ${guard_status}"
}

case "${1:-help}" in
  open) shift; open_note "${1:-}" ;;
  new) shift; new_note "$@" ;;
  capture) shift; capture_note "$@" ;;
  today) shift; today_note "$@" ;;
  spot) shift; spot_note "$@" ;;
  yt) shift; yt_note "$@" ;;
  pod) shift; pod_note "$@" ;;
  distill) shift; distill_note "$@" ;;
  grep) shift; grep_vault "${1:-}" ;;
  files) shift; files_vault "${1:-}" ;;
  recent) shift; recent_notes ;;
  sync) shift; sync_git "$@" ;;
  tags) shift; list_tags "$@" ;;
  tag) shift; add_tags "$@" ;;
  untag) shift; remove_tags "$@" ;;
  tagged) shift; list_tagged "${1:-}" ;;
  rename-tag) shift; rename_tag "$@" ;;
  audit) shift; audit_run "$@" ;;
  private) shift; private_cmd "$@" ;;
  crypt) shift; crypt_cmd "$@" ;;
  port) shift; port_cmd "$@" ;;
  obs) shift; open_obsidian ;;
  path) printf '%s\n' "$VAULT" ;;
  version|--version) printf 'okm v%s\n' "$OKM_VERSION" ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
